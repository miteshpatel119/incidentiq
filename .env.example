# =============================================================================
# IncidentIQ - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running the app.
#
#   cp .env.example .env
# =============================================================================

# OpenRouter API key for AI-powered root cause analysis
# Get your free key at https://openrouter.ai/keys
# A key is required for the AI investigation feature. Without it, the
# application will still simulate incidents and show mock results, but
# the "Analyze" button will show an error when calling the API.
#
# IMPORTANT: For production on Vercel, set this in your Vercel project's
# Environment Variables in the dashboard (Settings > Environment Variables).
# Do NOT commit your real API key to version control.
OPENROUTER_API_KEY=

# (Optional) Node environment
# Defaults to "development" if not set. Set to "production" on Vercel.
NODE_ENV=

# (Optional) Application URL — used for any redirects or callback URLs
# Defaults to http://localhost:5173 in development
PUBLIC_URL=